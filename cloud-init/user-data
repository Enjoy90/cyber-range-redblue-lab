#cloud-config
# Proxmox cloud-init: provisions the VM on first boot.
# Replace <REPO_URL> with your Git repository URL.

hostname: feedback-admin
manage_etc_hosts: true

users:
  - default
  - name: analyst
    groups: [adm, sudo]
    shell: /bin/bash
    lock_passwd: false
    # Password (blue_team_rocks) is set by scripts/bootstrap.sh (chpasswd).

write_files:
  - path: /etc/ssh/sshd_config.d/99-range.conf
    content: |
      Port 2275
      PasswordAuthentication yes

package_update: true
packages:
  - git
  - python3
  - ca-certificates
  - curl

runcmd:
  - systemctl restart ssh || systemctl restart sshd || true
  - git clone <REPO_URL> /opt/cyber-range
  - bash /opt/cyber-range/scripts/bootstrap.sh
